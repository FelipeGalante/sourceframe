{
  "name": "sourceframe",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint . --max-warnings=0",
    "generate:content": "node --import tsx scripts/generate-content.ts",
    "generate:agent-context": "node --import tsx scripts/generate-agent-context.ts",
    "screenshots": "node --import tsx scripts/capture-screenshots.ts",
    "typegen": "next typegen",
    "typecheck": "pnpm typegen && tsc --noEmit",
    "test": "pnpm typegen && node --import tsx --test tests/**/*.test.ts tests/**/*.test.tsx lib/content/**/__tests__/**/*.test.ts && node --test tests/**/*.test.mjs",
    "validate:content": "node --import tsx scripts/validate-content.ts"
  },
  "dependencies": {
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "estree-walker": "^3.0.3",
    "gray-matter": "^4.0.3",
    "hast-util-to-jsx-runtime": "^2.3.2",
    "mermaid": "^11.6.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.19.0",
    "eslint-config-next": "^15.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  }
}
